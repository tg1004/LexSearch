# =============================================================================
# LexSearch Production Environment Variables
# Copy these into Railway (backend) and Vercel (frontend) dashboards.
# NEVER commit real secrets to git.
# =============================================================================

# --- Railway: Backend service ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/railway
REDIS_URL=redis://default:PASSWORD@HOST:6379

JWT_SECRET_KEY=generate-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

GROQ_API_KEY=
GEMINI_API_KEY=
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_ORDER=groq,gemini
LLM_TIMEOUT_SECONDS=30

# Qdrant Cloud
QDRANT_URL=https://YOUR-CLUSTER.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=legal_judgements
QDRANT_TIMEOUT_SECONDS=300
QDRANT_UPLOAD_BATCH_SIZE=24

# Elastic Cloud
ELASTICSEARCH_URL=https://YOUR-DEPLOYMENT.region.gcp.cloud.es.io:443
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX=legal_judgements

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

ENVIRONMENT=production
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.up.railway.app

# --- Vercel: Frontend project (build-time) ---
# MUST include https:// — without it, fetch treats the value as a relative path!
VITE_API_URL=https://your-backend.up.railway.app

# --- Data pipeline (run locally or in a one-off job, not on Railway) ---
SCRAPE_TARGET_COUNT=10000
CHUNK_SIZE=800
CHUNK_OVERLAP=150
