# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lexsearch
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# LLM Providers (Phase 4+)
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
OLLAMA_BASE_URL=http://localhost:11434

# LLM Config
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_ORDER=groq,gemini
LLM_TIMEOUT_SECONDS=30

# Qdrant upload tuning (increase timeout / reduce batch for cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=legal_judgements
QDRANT_TIMEOUT_SECONDS=300
QDRANT_UPLOAD_BATCH_SIZE=24

# Elasticsearch (local Docker)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=legal_judgements
# Elastic Cloud (production) — use ONE auth method:
# ELASTICSEARCH_URL=https://YOUR-DEPLOYMENT.es.REGION.cloud.es.io:443
# ELASTICSEARCH_API_KEY=your-base64-api-key
# OR basic auth:
# ELASTICSEARCH_USER=elastic
# ELASTICSEARCH_PASSWORD=your-elastic-password

# Embeddings (Phase 3+)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Google OAuth (Phase 7+)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App Config
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

# Frontend (Vite)
VITE_API_URL=http://localhost:8000

# Data Pipeline (Phase 2)
SCRAPE_TARGET_COUNT=1000
SCRAPE_DELAY_SECONDS=1.5
SCRAPE_TIMEOUT_SECONDS=30
INDIANKANOON_BASE_URL=https://indiankanoon.org
